# Copy to .env.local and fill in. Never commit .env.local.

# Supabase (Project Settings → API). Use the EU-region project.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only. Bypasses RLS — used by Route Handlers for all mutations. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Weather provider: Open-Meteo. Free, no API key required for non-commercial/dev use.
# These defaults work out of the box; override only if you switch provider or self-host.
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
